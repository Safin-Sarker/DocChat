# ======================
# REQUIRED — App won't start without these
# ======================

# Authentication
SECRET_KEY=generate-a-strong-random-string-here

# Pinecone
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_ENVIRONMENT=gcp-starter
PINECONE_INDEX_NAME=docgraph-multimodal

# Neo4j (Aura Cloud)
NEO4J_URI=neo4j+ssc://your-instance-id.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_aura_password_here

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# ======================
# OPTIONAL
# ======================

# AWS S3 (leave empty to use local storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=local_storage
AWS_REGION=us-east-1
USE_LOCAL_STORAGE=true
LOCAL_STORAGE_PATH=./uploaded_files

# Application
DEBUG=False
LLM_MODEL=gpt-4o-mini

# Caching
ENABLE_EMBEDDING_CACHE=True
EMBEDDING_CACHE_TTL_SECONDS=86400
EMBEDDING_CACHE_MAX_SIZE=20000
ENABLE_QUERY_RESPONSE_CACHE=True
QUERY_RESPONSE_CACHE_TTL_SECONDS=900
QUERY_RESPONSE_CACHE_MAX_SIZE=2000
ENABLE_SEMANTIC_QUERY_CACHE=True
SEMANTIC_CACHE_SIMILARITY_THRESHOLD=0.92
SEMANTIC_CACHE_REQUIRE_EMPTY_HISTORY=True

# Rate Limiting (set to false to disable in development)
RATE_LIMIT_ENABLED=true

# OAuth (optional — for Google login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_FRONTEND_URL=http://localhost:5173
OAUTH_BACKEND_URL=http://localhost:8001
